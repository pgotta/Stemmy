# --- Stemmy ignores ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# generated at runtime
projects/*
!projects/.gitkeep
uploads/*
!uploads/.gitkeep
logs/*
!logs/.gitkeep
karaoke_jobs/
models_cache/
.stemmy.pid
.stemmy.browser.pid
.stemmy-browser-profile/

# Windows launchers are local/release-package files only.
# BUILD.md and docs/launchers contain their exact current source.
*.bat

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
